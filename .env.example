# ============================================================================
# kiro2api Docker Compose 环境配置示例
# ============================================================================
# 复制此文件为 .env 并根据需要修改配置
# 使用方式: docker-compose up -d

# ============================================================================
# Token 管理配置
# ============================================================================

# Token配置文件路径（相对于 docker-compose.yml）
# 请确保 tokens.json 文件存在且格式正确
# 格式参考: .env.example 中的 KIRO_AUTH_TOKEN 说明
KIRO_AUTH_TOKEN=/app/tokens.json

# Token选择策略
# - sequential: 顺序选择（粘性策略，用完一个再用下一个）
# - random: 随机选择（每次请求随机选择可用token）
# - round_robin: 轮询选择（默认，每次请求轮流使用各个token）
TOKEN_SELECTION_STRATEGY=round_robin

# RoundRobin 活跃池配置（用于 round_robin 策略）
# 设置活跃池大小，维护固定数量的健康账号进行轮询
# - 设置为 0 或不设置：使用全部账号轮询（默认行为）
# - 设置为 N（N > 0）：维护 N 个健康账号的活跃池，账号出问题时立即替换
# 建议值：总账号数的 1/3 到 1/2
# 例如：15个账号设置为5，30个账号设置为10
KIRO_BATCH_SIZE=0

# ============================================================================
# 认证配置
# ============================================================================

# 客户端认证Token（用于访问 /v1/* API）
# 请修改为强密码
KIRO_CLIENT_TOKEN=123456

# 管理员认证Token（用于访问 /v1/admin/* 管理接口）
# 不设置则禁用管理 API
# KIRO_ADMIN_TOKEN=your_admin_token_here

# ============================================================================
# 服务配置
# ============================================================================

# 服务端口（宿主机端口:容器端口）
# 默认映射 5656:8080，可根据需要修改
# PORT=8080

# Gin运行模式: debug, release, test
GIN_MODE=release

# ============================================================================
# 日志配置
# ============================================================================

# 日志级别: debug, info, warn, error
LOG_LEVEL=info

# 日志格式: text, json
LOG_FORMAT=json

# 控制台输出开关
LOG_CONSOLE=true

# 日志文件路径（容器内路径，需要挂载卷）
# LOG_FILE=/var/log/kiro2api.log

# ============================================================================
# 工具配置
# ============================================================================

# 工具描述的最大长度（字符数，默认: 10000）
# MAX_TOOL_DESCRIPTION_LENGTH=10000

# ============================================================================
# 代理池配置
# ============================================================================

# 代理池配置（支持两种方式）
# 方式1: 直接配置代理列表（逗号分隔）
# KIRO_PROXY_POOL=http://user:pass@proxy1.com:8080,http://user:pass@proxy2.com:8080

# 方式2: 配置文件路径（推荐，一行一个代理）
# KIRO_PROXY_POOL=/app/proxies.txt

# 健康检查URL（可选，默认 https://www.google.com）
# KIRO_PROXY_HEALTH_CHECK_URL=https://www.google.com

# 健康检查间隔（可选，默认 60s）
# KIRO_PROXY_HEALTH_CHECK_INTERVAL=60s

# 最大失败次数（可选，默认 3 次，超过则标记为不健康）
# KIRO_PROXY_MAX_FAILURES=3

# ============================================================================
# Docker 镜像配置
# ============================================================================

# 镜像标签（可选，默认使用 latest）
# 可用标签:
# - latest: 最新稳定版本
# - main: 主分支最新构建
# - v1.0.0: 特定版本号
# IMAGE_TAG=latest

# ============================================================================
# 使用说明
# ============================================================================
#
# 1. 准备 tokens.json 文件
#    - 复制 tokens.json.example 为 tokens.json
#    - 填入你的 AWS CodeWhisperer refresh tokens
#    - 格式参考: .env.example 中的 KIRO_AUTH_TOKEN 说明
#
# 2. 配置环境变量
#    - 复制此文件为 .env
#    - 修改 KIRO_CLIENT_TOKEN 为强密码
#    - 根据需要调整其他配置
#
# 3. 启动服务
#    docker-compose up -d
#
# 4. 查看日志
#    docker-compose logs -f kiro2api
#
# 5. 停止服务
#    docker-compose down
#
# 6. 更新镜像
#    docker-compose pull
#    docker-compose up -d
#
# 7. 健康检查
#    curl http://localhost:5656/v1/models
#
# 8. 管理 API（需要设置 KIRO_ADMIN_TOKEN）
#    # 查看所有 token 状态
#    curl -H "Authorization: Bearer your_admin_token" \
#         http://localhost:5656/v1/admin/tokens
#
#    # 删除失效的 token
#    curl -X DELETE \
#         -H "Authorization: Bearer your_admin_token" \
#         http://localhost:5656/v1/admin/tokens/invalid
#
# ============================================================================
# 最佳实践
# ============================================================================
#
# 1. 生产环境配置：
#    - 使用强密码作为 KIRO_CLIENT_TOKEN 和 KIRO_ADMIN_TOKEN
#    - 设置 GIN_MODE=release
#    - 配置多个 token 实现负载均衡（建议 10+ 个）
#    - 使用 round_robin 策略 + KIRO_BATCH_SIZE 活跃池（建议设置为总账号数的 1/3 到 1/2）
#    - 设置 LOG_LEVEL=info 或 warn
#    - 定期备份 tokens.json 和 aws_sso_cache 卷
#
# 2. 开发环境配置：
#    - 使用 GIN_MODE=debug
#    - 设置 LOG_LEVEL=debug
#    - 保持控制台输出: LOG_CONSOLE=true
#
# 3. 安全建议：
#    - 不要将 .env 和 tokens.json 提交到版本控制
#    - 定期轮换 KIRO_CLIENT_TOKEN 和 KIRO_ADMIN_TOKEN
#    - 使用防火墙限制访问端口
#    - 考虑使用反向代理（如 Nginx）添加 HTTPS
#
# 4. 性能优化：
#    - 根据负载调整资源限制（docker-compose.yml 中的 deploy 配置）
#    - 监控日志中的活跃池动态调整情况
#    - 定期检查 token 使用限制剩余量
#
